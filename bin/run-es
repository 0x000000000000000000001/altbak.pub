#!/usr/bin/env bash
set -e
cd "$(dirname "$0")/.."

mkdir -p .output.d/es-purs .spago.d/js
rm -rf output .spago spago.yaml spago.lock
ln -s .output.d/es-purs output
ln -s .spago.d/js .spago
ln -s spago.yaml.d/js.yaml spago.yaml
touch spago.lock.d/es.lock && ln -s spago.lock.d/es.lock spago.lock
npx spago build > /dev/null 2>&1
npx purs-backend-es build --output-dir .output.d/es > /dev/null 2>&1

echo "=== Arista ES ==="
time node -e "import('./.output.d/es/App/index.js').then(m => m.main())"
