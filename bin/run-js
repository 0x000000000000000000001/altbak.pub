#!/usr/bin/env bash
set -e
cd "$(dirname "$0")/.."

echo "=== Building JavaScript Backend ==="
mkdir -p output-js .spago-js
rm -rf output .spago spago.yaml
ln -s output-js output
ln -s .spago-js .spago
ln -s spago-js.yaml spago.yaml
npx spago build

echo "=== Executing JavaScript Backend (Node.js) ==="
node -e "import('./output/App/index.js').then(m => m.main())"
