#!/usr/bin/env bash
set -e
cd "$(dirname "$0")/.."

mkdir -p .output.d/js .spago.d/js
rm -rf output .spago spago.yaml spago.lock
ln -s .output.d/js output
ln -s .spago.d/js .spago
ln -s spago.yaml.d/js.yaml spago.yaml
touch spago.lock.d/js.lock && ln -s spago.lock.d/js.lock spago.lock
npx spago build > /dev/null 2>&1

echo "=== Native Node V8 ==="
time node -e "import('./output/App/index.js').then(m => m.main())"
