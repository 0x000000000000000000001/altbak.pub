#!/usr/bin/env bash
set -e
cd "$(dirname "$0")/.."

mkdir -p .output.d/scm .spago.d/scm
rm -rf output .spago spago.yaml spago.lock
ln -s .output.d/scm output
ln -s .spago.d/scm .spago
ln -s spago.yaml.d/scm.yaml spago.yaml
touch spago.lock.d/scm.lock && ln -s spago.lock.d/scm.lock spago.lock
npx spago fetch > /dev/null 2>&1
PATH="$(pwd)/bin:$PATH" npx purescm build > /dev/null 2>&1
PATH="$(pwd)/bin:$PATH" npx purescm bundle-app --main App > /dev/null 2>&1

echo "=== Chez Scheme ==="
export DYLD_LIBRARY_PATH="/opt/homebrew/lib:/opt/homebrew/opt/icu4c/lib"
time chez --program .output.d/scm/main
